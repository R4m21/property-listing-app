PORT=5000
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# PostgreSQL
# Either set DATABASE_URL directly (e.g. for Supabase/Neon)...
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/property_listing
# ...or leave DATABASE_URL unset and use these instead:
# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=postgres
# PGDATABASE=property_listing
# Set to true if your provider requires SSL
PGSSL=false

# Cloudinary (image uploads) - get these from your Cloudinary dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
